<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.effect.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.layout.*?>

<StackPane xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="mediaworking.GameSmiths.controllers.GameModeController">

    <!-- Background Image -->
    <ImageView fitHeight="600" fitWidth="800" preserveRatio="false">
        <image>
            <Image url="@1burhan.jpg" />
        </image>
    </ImageView>

    <AnchorPane prefHeight="600" prefWidth="800">
        <VBox alignment="CENTER" spacing="40" AnchorPane.bottomAnchor="0" AnchorPane.leftAnchor="0" AnchorPane.rightAnchor="0" AnchorPane.topAnchor="0">

            <Label style="-fx-font-size: 48; -fx-font-weight: bold; -fx-text-fill: white;">
                <effect>
                    <DropShadow color="rgba(0,0,0,0.5)" radius="10" spread="0.2" />
                </effect>
            </Label>

            <VBox alignment="CENTER" spacing="20" />
            <AnchorPane prefHeight="200.0" prefWidth="200.0">
                <children>
                    <Button fx:id="btnSinglePlayer" layoutX="190.0" layoutY="129.0" prefHeight="56.0" prefWidth="210.0" style="-fx-font-size: 22; -fx-font-weight: bold; -fx-font-family: 'Arial Black';                                    -fx-background-color: transparent; -fx-text-fill: white;                                    -fx-padding: 10 20; -fx-border-color: transparent;                                    -fx-border-width: 2; -fx-border-radius: 20;" text="Single Player">
                        <effect>
                            <DropShadow color="rgba(0,0,0,0.5)" radius="15" spread="0.2" />
                        </effect>
                    </Button>
                    <Button fx:id="btnMultiplayer" layoutX="402.0" layoutY="129.0" prefHeight="47.0" prefWidth="190.0" style="-fx-font-size: 22; -fx-font-weight: bold; -fx-font-family: 'Arial Black';                                    -fx-background-color: transparent; -fx-text-fill: white;                                    -fx-padding: 10 20; -fx-border-color: transparent;                                    -fx-border-width: 2; -fx-border-radius: 20;" text="Multiplayer">
                        <effect>
                            <DropShadow color="rgba(0,0,0,0.5)" radius="15" spread="0.2" />
                        </effect>
                    </Button>
               <Pane fx:id="siiiii" layoutX="209.0" layoutY="-105.0" prefHeight="237.0" prefWidth="181.0" />
               <AnchorPane fx:id="ffff" layoutX="406.0" layoutY="-103.0" prefHeight="228.0" prefWidth="181.0" />
                </children>
            </AnchorPane>
        </VBox>

        <Button fx:id="btnBack" layoutX="297.0" layoutY="502.0" prefHeight="58.0" prefWidth="210.0" style="-fx-font-size: 18; -fx-background-color: #e17055; -fx-text-fill: white; -fx-background-radius: 20; -fx-padding: 10 20;" text="⬅ Back" AnchorPane.leftAnchor="297.0" AnchorPane.topAnchor="502.0">
            <effect>
                <DropShadow color="rgba(0,0,0,0.3)" radius="5" spread="0.1" />
            </effect>
        </Button>
    </AnchorPane>
</StackPane>

<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.text.Font?>
<?import javafx.scene.effect.*?>

<VBox spacing="25" alignment="CENTER" xmlns:fx="http://javafx.com/fxml"
      fx:controller="mediaworking.GameSmiths.controllers.ClientController"
      style="-fx-background-color: linear-gradient(to bottom right, #1a2a6c, #b21f1f, #fdbb2d);">
    <padding>
        <Insets top="40" right="50" bottom="40" left="50"/>
    </padding>

    <Label text="Multiplayer Bingo Client" style="-fx-font-size: 36px; -fx-font-weight: bold; -fx-text-fill: white;">
        <font>
            <Font name="System Bold" size="36.0"/>
        </font>
        <effect>
            <DropShadow color="rgba(0,0,0,0.5)" radius="10" spread="0.2"/>
        </effect>
    </Label>

    <HBox spacing="30" alignment="CENTER">
        <RadioButton fx:id="clientRadio" text="Client" style="-fx-text-fill: white; -fx-font-size: 18px;"/>
    </HBox>

    <TextField fx:id="ipAddressField" promptText="Enter IP Address" style="-fx-background-radius: 8; -fx-font-size: 16px;"/>
    <TextField fx:id="portField" promptText="Enter Port" style="-fx-background-radius: 8; -fx-font-size: 16px;"/>

    <Button text="Connect to Server" onAction="#connectToServer"
            style="-fx-background-color: #4CAF50; -fx-text-fill: white; -fx-font-size: 20px; -fx-padding: 15 30; -fx-background-radius: 25;">
        <font>
            <Font name="System Bold" size="20.0"/>
        </font>
        <effect>
            <DropShadow color="rgba(0,0,0,0.3)" radius="10" spread="0.1"/>
        </effect>
    </Button>
</VBox>
<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.text.Font?>
<?import javafx.scene.effect.*?>

<VBox spacing="25" alignment="CENTER" xmlns:fx="http://javafx.com/fxml"
      fx:controller="mediaworking.GameSmiths.controllers.MultiplayerSetupController"
      style="-fx-background-color: linear-gradient(to bottom right, #141E30, #243B55);"
      prefHeight="600.0" prefWidth="800.0">
    <padding>
        <Insets top="40" right="50" bottom="40" left="50"/>
    </padding>

    <!-- Title Label -->
    <Label text="Multiplayer Bingo Setup" style="-fx-font-size: 36px; -fx-font-weight: bold; -fx-text-fill: linear-gradient(to right, #FFD700, #FFA500, #FF4500);">
        <font>
            <Font name="System Bold" size="36.0"/>
        </font>
        <effect>
            <DropShadow color="rgba(255,255,255,0.3)" radius="15" spread="0.3" offsetX="0" offsetY="4"/>
        </effect>
    </Label>
    <StackPane alignment="TOP_LEFT">
        <Button fx:id="backButton" onAction="#handleBackButton"
                style="-fx-background-color: #3498db;
                   -fx-background-radius: 30;
                   -fx-padding: 10 15 10 10;
                   -fx-font-size: 16px;
                   -fx-text-fill: white;
                   -fx-font-weight: bold;
                   -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.6), 5, 0, 0, 1);">
            <graphic>
                <HBox alignment="CENTER" spacing="5">
                    <Label text="⬅" style="-fx-font-size: 20px; -fx-text-fill: white;"/>
                    <Label text="Back" style="-fx-font-size: 16px; -fx-text-fill: white;"/>
                </HBox>
            </graphic>
        </Button>
        <StackPane.margin>
            <Insets top="10" right="10"/>
        </StackPane.margin>
    </StackPane>
    <!-- Radio Button Group for Online/Offline -->
    <HBox spacing="30" alignment="CENTER">
        <fx:define>
            <ToggleGroup fx:id="modeGroup"/>
        </fx:define>
        <RadioButton fx:id="onlineRadio" text="Online" toggleGroup="$modeGroup"
                     style="-fx-text-fill: #E0E0E0; -fx-font-size: 18px;">
            <effect>
                <DropShadow color="rgba(0,0,0,0.7)" radius="8" offsetX="2" offsetY="2"/>
            </effect>
        </RadioButton>
        <RadioButton fx:id="offlineRadio" text="Offline" toggleGroup="$modeGroup" selected="true"
                     style="-fx-text-fill: #E0E0E0; -fx-font-size: 18px;">
            <effect>
                <DropShadow color="rgba(0,0,0,0.7)" radius="8" offsetX="2" offsetY="2"/>
            </effect>
        </RadioButton>
    </HBox>

    <!-- Online Options Section -->
    <VBox fx:id="onlineOptions" visible="false" managed="false" spacing="20"
          style="-fx-background-color: rgba(0,0,0,0.3); -fx-padding: 25; -fx-background-radius: 15;">
        <effect>
            <DropShadow color="rgba(255,255,255,0.2)" radius="10" spread="0.1"/>
        </effect>
        <HBox spacing="30" alignment="CENTER">
            <fx:define>
                <ToggleGroup fx:id="roleGroup"/>
            </fx:define>
            <RadioButton fx:id="serverRadio" text="Server" toggleGroup="$roleGroup"
                         style="-fx-text-fill: #FFFFFF; -fx-font-size: 18px;"/>
            <RadioButton fx:id="clientRadio" text="Client" toggleGroup="$roleGroup"
                         style="-fx-text-fill: #FFFFFF; -fx-font-size: 18px;"/>
        </HBox>
        <TextField fx:id="ipAddressField" promptText="Enter IP Address (for client)"
                   style="-fx-background-radius: 8; -fx-font-size: 16px; -fx-text-fill: #000000;"/>
        <TextField fx:id="portField" promptText="Enter Port"
                   style="-fx-background-radius: 8; -fx-font-size: 16px; -fx-text-fill: #000000;"/>
    </VBox>

    <!-- Offline Options Section -->
    <VBox fx:id="offlineOptions" spacing="20"
          style="-fx-background-color: rgba(0,0,0,0.3); -fx-padding: 25; -fx-background-radius: 15;">
        <effect>
            <DropShadow color="rgba(255,255,255,0.2)" radius="10" spread="0.1"/>
        </effect>
        <HBox spacing="15" alignment="CENTER">
            <Label text="Number of Players:" style="-fx-text-fill: #FFFFFF; -fx-font-size: 18px;"/>
            <ComboBox fx:id="playerCountCombo" style="-fx-background-radius: 8; -fx-font-size: 16px;"/>
        </HBox>
        <VBox fx:id="playerNamesBox" spacing="15"/>
    </VBox>

    <!-- Board Size Selection -->
    <HBox spacing="15" alignment="CENTER"
          style="-fx-background-color: rgba(0,0,0,0.3); -fx-padding: 20; -fx-background-radius: 15;">
        <effect>
            <DropShadow color="rgba(255,255,255,0.2)" radius="10" spread="0.1"/>
        </effect>
        <Label text="Board Size:" style="-fx-text-fill: #FFFFFF; -fx-font-size: 18px;"/>
        <ComboBox fx:id="boardSizeCombo" style="-fx-background-radius: 8; -fx-font-size: 16px;"/>
    </HBox>

    <!-- Start Game Button -->
    <Button text="Start Game" onAction="#startGame"
            style="-fx-background-color: linear-gradient(to right, #32CD32, #228B22); -fx-text-fill: #FFFFFF; -fx-font-size: 20px; -fx-padding: 15 30; -fx-background-radius: 25;">
        <font>
            <Font name="System Bold" size="20.0"/>
        </font>
        <effect>
            <DropShadow color="rgba(0,0,0,0.7)" radius="10" spread="0.1"/>
        </effect>
    </Button>
</VBox>

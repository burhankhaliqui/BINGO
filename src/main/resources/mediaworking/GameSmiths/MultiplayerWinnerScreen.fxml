<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.effect.*?>
<?import javafx.geometry.*?>

<StackPane xmlns="http://javafx.com/javafx/16" xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="mediaworking.GameSmiths.controllers.MultiplayerWinnerController"
           style="-fx-background-color: linear-gradient(to bottom right, #141E30, #243B55);">

    <VBox alignment="CENTER" spacing="20.0" maxWidth="800.0" maxHeight="600.0"
          style="-fx-background-color: rgba(0, 0, 0, 0.3); -fx-background-radius: 15; -fx-padding: 30;">
        <effect>
            <DropShadow color="rgba(255, 255, 255, 0.2)" radius="20" spread="0.1" />
        </effect>

        <!-- Title -->
        <Label text="🎉 Congratulations! 🎉" style="-fx-font-size: 48px; -fx-font-weight: bold;
                                                  -fx-text-fill: linear-gradient(to right, #FFD700, #FFA500, #FF4500);">
            <effect>
                <Glow level="0.8" />
            </effect>
        </Label>

        <!-- Winner Display -->
        <Label fx:id="winnerLabel" text="Winner: Player 1" wrapText="true" textAlignment="CENTER"
               style="-fx-font-size: 36px; -fx-font-weight: bold;
                      -fx-text-fill: linear-gradient(to right, #32CD32, #00FA9A);
                      -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.8), 5, 0, 0, 0);">
            <VBox.margin>
                <Insets bottom="20.0" />
            </VBox.margin>
        </Label>

        <!-- Scrollable Players Information -->
        <ScrollPane fitToWidth="true" style="-fx-background-color: transparent; -fx-border-color: transparent;">
            <VBox fx:id="playersContainer" spacing="10.0" alignment="CENTER"
                  style="-fx-padding: 10; -fx-background-color: rgba(255,255,255,0.1); -fx-background-radius: 10;">
                <effect>
                    <DropShadow color="rgba(0, 0, 0, 0.5)" radius="10" spread="0.1" />
                </effect>
                <!-- Example Player Scores -->
                <Label text="Player 1: 10 Points" style="-fx-font-size: 24px; -fx-text-fill: #FFFFFF;" />
                <Label text="Player 2: 8 Points" style="-fx-font-size: 24px; -fx-text-fill: #FFFFFF;" />
                <Label text="Player 3: 5 Points" style="-fx-font-size: 24px; -fx-text-fill: #FFFFFF;" />
            </VBox>
        </ScrollPane>

        <!-- Return to Main Menu Button -->
        <Button text="Return to Main Menu" onAction="#returnToMainMenu" visible="false"
                style="-fx-background-color: linear-gradient(to right, #32CD32, #228B22);
                       -fx-text-fill: #FFFFFF;
                       -fx-font-size: 24px;
                       -fx-font-weight: bold;
                       -fx-padding: 10 30;
                       -fx-cursor: hand;
                       -fx-background-radius: 20;
                       -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.6), 5, 0.0, 0, 1);">
        </Button>

    </VBox>

</StackPane>
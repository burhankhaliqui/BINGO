<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.text.Font?>
<?import javafx.scene.effect.*?>
<?import javafx.scene.image.*?>

<StackPane xmlns="http://javafx.com/javafx"
           xmlns:fx="http://javafx.com/fxml"
           fx:controller="mediaworking.GameSmiths.controllers.HowToPlayController"
           prefWidth="800" prefHeight="600">

    <!-- Background Image -->
    <ImageView fitWidth="800" fitHeight="600" preserveRatio="false">
        <image>
            <Image url="@1abcde.jpg"/> <!-- Make sure this image file exists in the same directory -->
        </image>
    </ImageView>

    <!-- Existing content -->
    <StackPane style="-fx-background-color: rgba(44,62,80,0.7);">
        <VBox spacing="20" alignment="CENTER" maxWidth="800" maxHeight="600"
              style="-fx-background-color: rgba(255,255,255,0.1); -fx-background-radius: 20; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.4), 10, 0, 0, 0);">
            <padding>
                <Insets top="30" right="40" bottom="30" left="40"/>
            </padding>

            <Label text="How to Play Bingo"
                   style="-fx-font-size: 48px; -fx-font-weight: bold; -fx-text-fill: #FFFFFF; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.4), 4, 0, 0, 2);">
                <font>
                    <Font name="Arial Bold" size="48"/>
                </font>
            </Label>

            <ScrollPane fitToWidth="true" prefHeight="400"
                        style="-fx-background-color: transparent; -fx-background: transparent; -fx-border-color: transparent;">
                <VBox spacing="25">
                    <Label text="Follow these steps to play Bingo:"
                           style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #FFFFFF; -fx-underline: true; -fx-effect: dropshadow(gaussian, rgba(255,255,255,0.2), 2, 0, 0, 1);"/>
                    <VBox spacing="15">
                        <Label text="1. Distribute Bingo cards and markers to all players."
                               style="-fx-font-size: 18px; -fx-text-fill: #FFFFFF; -fx-padding: 15 20; -fx-background-color: rgba(255,255,255,0.1); -fx-background-radius: 10; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.2), 3, 0, 0, 1);"/>
                        <Label text="2. Randomly draw and announce numbers from the pool."
                               style="-fx-font-size: 18px; -fx-text-fill: #FFFFFF; -fx-padding: 15 20; -fx-background-color: rgba(255,255,255,0.1); -fx-background-radius: 10; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.2), 3, 0, 0, 1);"/>
                        <Label text="3. Players mark the announced numbers on their cards if present."
                               style="-fx-font-size: 18px; -fx-text-fill: #FFFFFF; -fx-padding: 15 20; -fx-background-color: rgba(255,255,255,0.1); -fx-background-radius: 10; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.2), 3, 0, 0, 1);"/>
                        <Label text="4. Continue drawing and announcing numbers until a player completes the required pattern."
                               style="-fx-font-size: 18px; -fx-text-fill: #FFFFFF; -fx-padding: 15 20; -fx-background-color: rgba(255,255,255,0.1); -fx-background-radius: 10; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.2), 3, 0, 0, 1);"/>
                        <Label text="5. The first player to complete the pattern shouts &quot;Bingo!&quot;"
                               style="-fx-font-size: 18px; -fx-text-fill: #FFFFFF; -fx-padding: 15 20; -fx-background-color: rgba(255,255,255,0.1); -fx-background-radius: 10; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.2), 3, 0, 0, 1);"/>
                        <Label text="6. Verify the player's card to confirm the win."
                               style="-fx-font-size: 18px; -fx-text-fill: #FFFFFF; -fx-padding: 15 20; -fx-background-color: rgba(255,255,255,0.1); -fx-background-radius: 10; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.2), 3, 0, 0, 1);"/>
                        <Label text="7. If the win is valid, that player is declared the winner; if not, the game continues."
                               style="-fx-font-size: 18px; -fx-text-fill: #FFFFFF; -fx-padding: 15 20; -fx-background-color: rgba(255,255,255,0.1); -fx-background-radius: 10; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.2), 3, 0, 0, 1);"/>
                        <Label text="8. Play additional rounds with new patterns as desired."
                               style="-fx-font-size: 18px; -fx-text-fill: #FFFFFF; -fx-padding: 15 20; -fx-background-color: rgba(255,255,255,0.1); -fx-background-radius: 10; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.2), 3, 0, 0, 1);"/>
                    </VBox>
                </VBox>
            </ScrollPane>

            <Button text="Back to Menu" onAction="#returnToMenu"
                    style="-fx-background-color: #3498db; -fx-text-fill: white; -fx-font-size: 18px; -fx-font-weight: bold; -fx-padding: 12 25; -fx-background-radius: 25; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.3), 5, 0, 0, 1);">
                <effect>
                    <DropShadow color="rgba(0,0,0,0.3)" radius="5" spread="0.2"/>
                </effect>
            </Button>
        </VBox>
    </StackPane>
</StackPane>
<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.layout.*?>

<StackPane prefHeight="600" prefWidth="800" xmlns:fx="http://javafx.com/fxml/1" xmlns="http://javafx.com/javafx/17.0.12" fx:controller="mediaworking.GameSmiths.SinglePlayerBoardController">

    <!-- Background Image -->
    <ImageView fitHeight="600" fitWidth="800" preserveRatio="false">
        <image>
            <Image url="@21.jpeg" />
        </image>
    </ImageView>

    <BorderPane>
        <top>
            <HBox alignment="CENTER" spacing="10">
                <padding>
                    <Insets bottom="20" left="20" right="20" top="20" />
                </padding>
                <Button fx:id="returnToMenuButton" onAction="#returnToMenu" style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-padding: 12 24; -fx-background-radius: 25; -fx-background-color: #3498db; -fx-text-fill: white; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.3), 5, 0, 0, 1);" text="Return to Menu" />
                <Region HBox.hgrow="ALWAYS" />
                <Label fx:id="currentPlayerLabel" style="-fx-font-size: 28px; -fx-font-weight: bold; -fx-text-fill: #ffffff; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.8), 5, 0, 0, 1);" />
                <Region HBox.hgrow="ALWAYS" />
                <Button fx:id="exitButton" onAction="#exitGame" style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-padding: 12 24; -fx-background-radius: 25; -fx-background-color: #e74c3c; -fx-text-fill: white; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.3), 5, 0, 0, 1);" text="Exit Game" />
            </HBox>
        </top>

        <center>
            <VBox alignment="CENTER" spacing="20">
                <Label style="-fx-font-size: 22px; -fx-font-weight: bold; -fx-text-fill: #ffffff; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.5), 2, 0, 0, 1);" text="Player" />
                <VBox fx:id="playerContainer" alignment="CENTER" spacing="10" style="-fx-background-color: rgba(255,255,255,0.2); -fx-padding: 20; -fx-background-radius: 15; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.4), 10, 0, 0, 5);">
                    <GridPane fx:id="playerBoard" alignment="CENTER" hgap="5" style="-fx-background-color: rgba(255,255,255,0.1); -fx-padding: 10; -fx-background-radius: 10;" vgap="5" />
                </VBox>
                <VBox fx:id="botContainer" alignment="CENTER" managed="false" spacing="10" style="-fx-background-color: rgba(255,255,255,0.2); -fx-padding: 20; -fx-background-radius: 15; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.4), 10, 0, 0, 5);" visible="false">
                    <Label style="-fx-font-size: 22px; -fx-font-weight: bold; -fx-text-fill: #ffffff; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.5), 2, 0, 0, 1);" text="Bot" />
                    <GridPane fx:id="botBoard" alignment="CENTER" hgap="5" style="-fx-background-color: rgba(255,255,255,0.1); -fx-padding: 10; -fx-background-radius: 10;" vgap="5" />
                </VBox>
            </VBox>
        </center>

        <bottom>
            <HBox alignment="CENTER" spacing="20">
                <padding>
                    <Insets bottom="20" left="20" right="20" top="20" />
                </padding>
            </HBox>
        </bottom>
    </BorderPane>
</StackPane>